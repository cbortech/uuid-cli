{
  "name": "@cbortech/uuid-cli",
  "version": "0.2.0",
  "description": "UUID generation and inspection CLI tool (RFC 9562)",
  "keywords": [
    "uuid",
    "uuidv7",
    "rfc9562",
    "rfc4122",
    "cli"
  ],
  "homepage": "https://cbor.tech/uuid/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbortech/uuid-cli.git"
  },
  "bugs": {
    "url": "https://github.com/cbortech/uuid-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "author": "Yasuhiro Kudo <ykudo@ykudo.org>",
  "type": "module",
  "bin": {
    "uuid": "dist/uuid.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@cbortech/uuid": "^0.1.2",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "esbuild": "^0.25.12",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
